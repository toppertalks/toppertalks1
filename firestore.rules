rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users — can only read/write their own profile ──
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Notifications sub-collection
      match /notifications/{notifId} {
        allow read, write: if request.auth.uid == uid;
      }
    }

    // ── Toppers — anyone logged in can browse, toppers update their own ──
    match /toppers/{uid} {
      allow read: if true;  // public browsing (no login needed to see toppers)
      allow update: if request.auth != null && request.auth.uid == uid;
      allow create: if false; // only admin / seed script can create topper docs
    }

    // ── Sessions — student or topper of that session can access ──
    match /sessions/{sessionId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.studentId
                   || request.auth.uid == resource.data.topperId);
      allow create: if request.auth != null;
      allow update: if request.auth != null
                  && (request.auth.uid == resource.data.studentId
                   || request.auth.uid == resource.data.topperId);
    }

    // ── Ratings — any logged-in user can submit, anyone can read ──
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ── Mentor Applications — user writes their own, admin reads all ──
    match /mentorApplications/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null && request.auth.uid == uid;
    }
  }
}
