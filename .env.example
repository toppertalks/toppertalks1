# ── Server ─────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=4000
FRONTEND_URL=http://localhost:3000

# CORS — comma-separated allowed origins. Never use * with credentials.
# Production: ALLOWED_ORIGINS=https://toppertalks.com,https://www.toppertalks.com
ALLOWED_ORIGINS=http://localhost:3000

# ── PostgreSQL ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:6432/toppertalks
DATABASE_URL_READER=
# Local dev (direct, no PgBouncer):
# DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/toppertalks

# ── Redis ───────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# With password: REDIS_URL=redis://:yourpassword@localhost:6379/0
# Local dev macOS: brew install redis && brew services start redis

# ── Postgres password (docker-compose only) ────────────────────────────────────
POSTGRES_PASSWORD=yourpassword

# ── Firebase ───────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Sentry (error tracking) ────────────────────────────────────────────────────
# Get from: sentry.io → Project Settings → Client Keys (DSN)
# Leave empty to disable (safe for local dev)
SENTRY_DSN=

# ── Rate limiting ───────────────────────────────────────────────────────────────
# Max requests per minute per client IP across all routes. 0 = unlimited.
RATE_LIMIT_PER_MINUTE=120

# ── Debug (development only) ───────────────────────────────────────────────────
# SQL_ECHO=true   # logs every SQL statement — never enable in production
